#!/bin/sh

echo "Moving into the 'front' directory to run tests..."

# Navigate to the React app folder
cd front-end || { echo "❌ Could not find the 'front-end' folder"; exit 1; }

# Run the tests once
npm test -- --watchAll=false

if [ $? -ne 0 ]; then
  echo "❌ Tests failed. Push aborted."
  exit 1
fi

echo "✅ All tests passed. Proceeding with push."
exit 0